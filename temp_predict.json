[{"line": 6, "text": "2. Prediction Interface for new events"}, {"line": 617, "text": "[\"\ud83d\udcca Dashboard\", \"\ud83d\uddfa\ufe0f Event Map\", \"\ud83d\udd2e Predict Event\","}, {"line": 638, "text": "elif page == \"\ud83d\udd2e Predict Event\":"}, {"line": 639, "text": "render_prediction_interface(df)"}, {"line": 848, "text": "# PAGE: PREDICT EVENT"}, {"line": 851, "text": "def render_prediction_interface(df):"}, {"line": 852, "text": "\"\"\"Interface for predicting new events with data-driven accuracy.\"\"\""}, {"line": 855, "text": "<h1>\ud83d\udd2e Event Impact Predictor</h1>"}, {"line": 856, "text": "<p>Enter event details to get data-driven predictions, diversion routes, and resource deployment plans</p>"}, {"line": 968, "text": "# \u2500\u2500 PREDICT BUTTON \u2500\u2500"}, {"line": 969, "text": "if st.button(\"\ud83d\udd2e Predict Impact & Generate Action Plan\", type=\"primary\", use_container_width=True):"}, {"line": 974, "text": "# DATA-DRIVEN PREDICTIONS"}, {"line": 976, "text": "# Severity prediction \u2014 from data stats"}, {"line": 998, "text": "# Duration prediction \u2014 from data stats (more accurate than ML model for this dataset)"}, {"line": 1003, "text": "predicted_duration = med_dur * (1.25 if is_rush else 1.0) * (0.9 if is_weekend else 1.0)"}, {"line": 1007, "text": "# Closure prediction \u2014 from data stats"}, {"line": 1019, "text": "predictions = {"}, {"line": 1026, "text": "\"p50\": predicted_duration,"}, {"line": 1060, "text": "plan = recommender.recommend(event_profile, predictions)"}, {"line": 1068, "text": "# \u2500\u2500 Phase 1: Prediction Results \u2500\u2500"}, {"line": 1069, "text": "st.markdown(\"##### \ud83c\udfaf Prediction Results\")"}, {"line": 1079, "text": "st.metric(\"\u23f1\ufe0f Est. Duration\", f\"{predicted_duration:.1f}h\","}, {"line": 1138, "text": "\"Hours\": [p10_adj, p10_adj * 1.5, predicted_duration, p90_adj * 0.6, p90_adj],"}, {"line": 1557, "text": "st.markdown(\"##### \u23f1\ufe0f Duration Prediction Model\")"}, {"line": 1628, "text": "<p>Continuous improvement through systematic analysis of prediction accuracy and bias</p>"}, {"line": 1653, "text": "st.markdown(\"##### \ud83c\udfaf Severity Prediction Bias by Event Cause\")"}, {"line": 1675, "text": "title=dict(text=\"Prediction Bias (Positive = Over-predicting severity)\","}, {"line": 1687, "text": "st.markdown(\"##### \u23f1\ufe0f Duration Prediction Bias\")"}, {"line": 1692, "text": "\"Under-predicting\" if report[\"duration_bias_hours\"] < 0 else \"Over-predicting\")"}, {"line": 1717, "text": "title=dict(text=\"Prediction/Actual Ratio (1.0 = perfect, <1 = under-predicting)\","}]